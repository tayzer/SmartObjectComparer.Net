<Window x:Class="ComparisonTool.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        xmlns:local="clr-namespace:ComparisonTool.Desktop"
        Title="Comparison Tool"
        Height="900"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <blazor:BlazorWebView x:Name="blazorWebView"
                           HostPage="wwwroot/index.html"
                           Services="{x:Static local:App.Services}">
        <blazor:BlazorWebView.RootComponents>
            <blazor:RootComponent Selector="#app"
                                   ComponentType="{x:Type local:Main}" />
        </blazor:BlazorWebView.RootComponents>
    </blazor:BlazorWebView>
</Window>
