{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ComparisonSettings": {
    "MaxFileSizeBytes": 52428800
  },
  "AcceptedDifferences": {
    "Enabled": true,
    "StorePath": "Data/accepted-differences.json"
  },
  "RequestComparison": {
    "DefaultTimeoutMs": 30000,
    "MaxConcurrency": 64,
    "EndpointOptions": {
      "AllowCustom": true,
      "Endpoints": []
    }
  }
}
