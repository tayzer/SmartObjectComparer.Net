@namespace ComparisonTool.UI.Comparison
@using System.Text.RegularExpressions
@using ComparisonTool.Core
@using ComparisonTool.Core.AcceptedDifferences
@using ComparisonTool.Core.Utilities
@using ComparisonTool.Core.Comparison.Analysis
@using ComparisonTool.Core.Comparison.Results
@using ComparisonTool.Core.Abstractions
@using KellermanSoftware.CompareNetObjects
@using Microsoft.AspNetCore.Components
@inject RawContentService RawContentService
@inject IAcceptedDifferenceService AcceptedDifferenceService

<style>
    .diff-expected-cell {
        background-color: rgba(46, 125, 50, 0.1) !important;
        border-left: 3px solid #2e7d32 !important;
    }
    
    .diff-actual-cell {
        background-color: rgba(211, 47, 47, 0.1) !important;
        border-left: 3px solid #d32f2f !important;
    }
    
    .diff-value-expected {
        background-color: rgba(46, 125, 50, 0.2);
        color: #1b5e20;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 4px;
        font-family: 'Consolas', 'Monaco', monospace;
        font-size: 0.875rem;
    }
    
    .diff-value-actual {
        background-color: rgba(211, 47, 47, 0.2);
        color: #b71c1c;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 4px;
        font-family: 'Consolas', 'Monaco', monospace;
        font-size: 0.875rem;
    }
</style>

<MudPaper Elevation="2" Class="mt-4" id="detailed-differences-section">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="pa-3" Style="background: var(--mud-palette-surface);">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Compare" Class="mr-2" />
                Detailed Comparison
            </MudText>
            <MudText Typo="Typo.caption" Color="Color.Default">
                @SelectedPair.File1Name vs @SelectedPair.File2Name
            </MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudTooltip Text="Toggle between structured differences and full file side-by-side comparison">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.ViewList" Size="Size.Small" Color="@(!showFullFileView ? Color.Primary : Color.Default)" />
                    <MudSwitch T="bool" @bind-Value="showFullFileView" 
                               Color="Color.Primary" 
                               Label="" 
                               Class="ma-0" />
                    <MudIcon Icon="@Icons.Material.Filled.ViewColumn" Size="Size.Small" Color="@(showFullFileView ? Color.Primary : Color.Default)" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@(showFullFileView ? "Full File View" : "Structured View")</MudText>
                </MudStack>
            </MudTooltip>
            <MudButton Variant="Variant.Outlined" 
                       Color="Color.Primary"
                       Size="Size.Small" 
                       StartIcon="@Icons.Material.Filled.Download"
                       OnClick="ExportResults">
                Export This Result
            </MudButton>
        </MudStack>
    </MudStack>
    <MudDivider />
</MudPaper>

@if (showFullFileView)
{
    <MudPaper Elevation="2" Class="mt-4 pa-4">
        <SideBySideFileView ContentA="@rawContentA"
                            ContentB="@rawContentB"
                            FileNameA="@SelectedPair.File1Name"
                            FileNameB="@SelectedPair.File2Name"
                            IsTruncatedA="@rawContentTruncatedA"
                            IsTruncatedB="@rawContentTruncatedB"
                            IsLoading="@isLoadingRawContent"
                            ErrorMessage="@rawContentErrorMessage" />
    </MudPaper>
}
else if (!DifferenceSummary.AreEqual)
{
    <MudPaper Elevation="2" Class="mt-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="pa-3">
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-2" />
                All Differences
            </MudText>
            <MudButton Variant="Variant.Text" 
                       Size="Size.Small" 
                       OnClick="OnToggleShowAll">
                @(ShowAllDifferences ? "Show Top 100 Per Group" : "Show All Differences")
            </MudButton>
        </MudStack>
        <MudDivider />
        
        <div class="pa-4">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-4 flex-wrap">
                <MudTextField @bind-Value="SearchFilter" 
                              Placeholder="Search differences..." 
                              Variant="Variant.Outlined" 
                              Adornment="Adornment.Start" 
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              Margin="Margin.Dense"
                              Style="min-width: 260px;" />
                @if (AcceptedDifferenceService.IsEnabled)
                {
                    <MudSwitch T="bool"
                               @bind-Value="HideTrackedDifferences"
                               Color="Color.Primary"
                               Label="Hide accepted / known bugs"
                               Class="ma-0" />
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">
                        @GetUntrackedDifferenceCount() New
                    </MudChip>
                    @if (GetAcceptedDifferenceCount() > 0)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">
                            @GetAcceptedDifferenceCount() Accepted
                        </MudChip>
                    }
                    @if (GetKnownBugCount() > 0)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">
                            @GetKnownBugCount() Known Bugs
                        </MudChip>
                    }
                    @if (GetFixedVerifiedCount() > 0)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">
                            @GetFixedVerifiedCount() Fixed / Verified
                        </MudChip>
                    }
                }
            </MudStack>

            @{
                var groupRenderContext = GetGroupRenderContext();
            }
            
            @foreach (var group in groupRenderContext.Groups)
            {
                string groupKey = group.Key;
                bool isCollapsed = IsGroupCollapsed(groupKey);
                var diffCount = group.Count();
                
                <MudPaper Elevation="1" Class="mb-3">
                    <MudStack Row="true" 
                              Justify="Justify.SpaceBetween" 
                              AlignItems="AlignItems.Center" 
                              Class="pa-3 cursor-pointer"
                              Style="background: var(--mud-palette-background-grey);"
                              @onclick="() => ToggleGroupCollapse(groupKey)">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@(isCollapsed ? Icons.Material.Filled.ChevronRight : Icons.Material.Filled.ExpandMore)" />
                            <MudText Typo="Typo.subtitle1"><strong>@groupKey</strong></MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Error">@diffCount diffs</MudChip>
                        </MudStack>
                    </MudStack>
                    
                    @if (!isCollapsed)
                    {
                        <MudDivider />
                        <MudDataGrid T="DifferenceItem" 
                                     Items="@GetGroupItems(group)" 
                                     Dense="true" 
                                     Hover="true"
                                     Striped="false"
                                     Filterable="false"
                                     SortMode="SortMode.Single"
                                     RowsPerPage="25">
                            <Columns>
                                <TemplateColumn Title="Tracking" Sortable="true">
                                    <CellTemplate>
                                        @if (context.Item.MatchedProfile != null)
                                        {
                                            <MudChip T="string"
                                                     Size="Size.Small"
                                                     Color="@GetProfileChipColor(context.Item.MatchedProfile.Status)">
                                                @GetProfileLabel(context.Item.MatchedProfile)
                                            </MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default">New</MudChip>
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Property="x => x.DisplayPropertyName" Title="Property" Sortable="true">
                                    <CellTemplate>
                                        <code style="font-size: 0.85rem;">@context.Item.DisplayPropertyName</code>
                                    </CellTemplate>
                                </PropertyColumn>
                                <TemplateColumn Title="Expected (A)" CellClass="diff-expected-cell">
                                    <CellTemplate>
                                        <span class="diff-value-expected">@context.Item.ExpectedValue</span>
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Actual (B)" CellClass="diff-actual-cell">
                                    <CellTemplate>
                                        <span class="diff-value-actual">@context.Item.ActualValue</span>
                                    </CellTemplate>
                                </TemplateColumn>
                                @if (AcceptedDifferenceService.IsEnabled)
                                {
                                    <TemplateColumn Title="Action">
                                        <CellTemplate>
                                            <MudButton Variant="Variant.Text"
                                                       Color="Color.Primary"
                                                       Size="Size.Small"
                                                       StartIcon="@Icons.Material.Filled.BookmarkAdd"
                                                       OnClick="@(() => OpenProfileDialog(context.Item))">
                                                @(context.Item.MatchedProfile == null ? "Track" : "Edit")
                                            </MudButton>
                                        </CellTemplate>
                                    </TemplateColumn>
                                }
                            </Columns>
                            <PagerContent>
                                <MudDataGridPager T="DifferenceItem" />
                            </PagerContent>
                        </MudDataGrid>
                        
                        @if (diffCount > 100 && !ShowAllDifferences)
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true" Class="mx-3 mb-3">
                                And @(diffCount - 100) more differences in this group...
                            </MudAlert>
                        }
                    }
                </MudPaper>
            }

            @if (groupRenderContext.HasMore)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">
                    Rendering @groupRenderContext.RenderedCount of @groupRenderContext.TotalCount groups to keep the UI responsive.
                    <MudStack Row="true" Spacing="1" Class="mt-2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="LoadMoreGroups">
                            Load @GroupRenderIncrement More
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" OnClick="LoadAllGroups">
                            Load All Groups
                        </MudButton>
                    </MudStack>
                </MudAlert>
            }
        </div>
    </MudPaper>
}

<MudDialog @bind-Visible="showProfileDialog" Options="profileDialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Track Difference Profile</MudText>
    </TitleContent>
    <DialogContent>
        @if (editingDifferenceItem != null)
        {
            <MudStack Spacing="2">
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    Profiles are stored in a shared JSON file. Point Web and Desktop to the same absolute or network store path when you need cross-machine sharing.
                </MudAlert>
                <MudText Typo="Typo.body2"><strong>Property:</strong> @editingDifferenceItem.SourceDifference.PropertyName</MudText>
                <MudText Typo="Typo.body2"><strong>Fingerprint Path:</strong> @editingDifferenceItem.GroupKey</MudText>
                <MudText Typo="Typo.body2"><strong>Expected:</strong> @editingDifferenceItem.ExpectedValue</MudText>
                <MudText Typo="Typo.body2"><strong>Actual:</strong> @editingDifferenceItem.ActualValue</MudText>

                <MudSelect T="AcceptedDifferenceStatus"
                           @bind-Value="editorStatus"
                           Label="Classification"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    <MudSelectItem Value="@AcceptedDifferenceStatus.AcceptedDifference">Accepted Difference</MudSelectItem>
                    <MudSelectItem Value="@AcceptedDifferenceStatus.KnownBug">Known Bug</MudSelectItem>
                    <MudSelectItem Value="@AcceptedDifferenceStatus.FixedVerified">Fixed / Verified</MudSelectItem>
                </MudSelect>

                @if (editorStatus == AcceptedDifferenceStatus.KnownBug)
                {
                    <MudTextField @bind-Value="editorTicketId"
                                  Label="Ticket ID"
                                  Placeholder="BUG-1234"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Required="true" />
                }

                <MudTextField @bind-Value="editorNotes"
                              Label="Notes"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Lines="3" />

                @if (!string.IsNullOrWhiteSpace(profileDialogErrorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                        @profileDialogErrorMessage
                    </MudAlert>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="CloseProfileDialog">Cancel</MudButton>
        <MudButton Variant="Variant.Text"
                   Color="Color.Error"
                   Disabled="@(editingDifferenceItem?.MatchedProfile == null)"
                   OnClick="ClearProfileAsync">
            Clear Profile
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(!CanSaveProfile)"
                   OnClick="SaveProfileAsync">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public FilePairComparisonResult SelectedPair { get; set; }

    [Parameter]
    public DifferenceSummary DifferenceSummary { get; set; }

    [Parameter]
    public ComparisonResult ComparisonResult { get; set; }

    [Parameter]
    public bool ShowAllDifferences { get; set; }

    [Parameter]
    public EventCallback OnToggleShowAll { get; set; }

    [Parameter]
    public EventCallback OnExportResults { get; set; }

    [Parameter]
    public MultiFolderComparisonResult FolderResult { get; set; }

    private static readonly DialogOptions profileDialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        CloseButton = true,
    };

    private string _searchFilter = string.Empty;
    private string SearchFilter
    {
        get => _searchFilter;
        set
        {
            var normalized = value ?? string.Empty;
            if (string.Equals(_searchFilter, normalized, StringComparison.Ordinal))
            {
                return;
            }

            _searchFilter = normalized;
            renderedGroupLimit = InitialGroupRenderLimit;
        }
    }

    private Dictionary<string, bool> groupCollapsedStates = new Dictionary<string, bool>();
    private int renderedGroupLimit = InitialGroupRenderLimit;
    private string? lastRenderedPairKey;
    private bool showProfileDialog;
    private DifferenceItem? editingDifferenceItem;
    private AcceptedDifferenceStatus editorStatus = AcceptedDifferenceStatus.AcceptedDifference;
    private string editorTicketId = string.Empty;
    private string editorNotes = string.Empty;
    private string? profileDialogErrorMessage;
    
    private const int InitialGroupRenderLimit = 150;
    private const int GroupRenderIncrement = 150;
    private const int GroupPreviewDifferenceLimit = 100;
    
    // Full file view state
    private bool showFullFileView;
    private string rawContentA = "";
    private string rawContentB = "";
    private bool rawContentTruncatedA;
    private bool rawContentTruncatedB;
    private bool isLoadingRawContent;
    private string? rawContentErrorMessage;
    private string? lastLoadedPairKey;
    
    // Grid item for differences
    public class DifferenceItem
    {
        public Difference SourceDifference { get; set; } = null!;
        public string GroupKey { get; set; } = string.Empty;
        public string Fingerprint { get; set; } = string.Empty;
        public string PropertyName { get; set; } = "";
        public string DisplayPropertyName { get; set; } = "";
        public string ExpectedValue { get; set; } = "";
        public string ActualValue { get; set; } = "";
        public AcceptedDifferenceProfile? MatchedProfile { get; set; }
    }

    private sealed class GroupRenderContext
    {
        public List<IGrouping<string, DifferenceItem>> Groups { get; set; } = new();
        public int TotalCount { get; set; }
        public int RenderedCount => Groups.Count;
        public bool HasMore => TotalCount > RenderedCount;
    }

    private List<DifferenceItem> DifferenceItems { get; set; } = new();
    private bool HideTrackedDifferences { get; set; } = true;

    protected override async Task OnParametersSetAsync()
    {
        var currentPairKey = $"{SelectedPair?.File1Path}|{SelectedPair?.File2Path}|{SelectedPair?.RequestRelativePath}";
        if (!string.Equals(currentPairKey, lastRenderedPairKey, StringComparison.Ordinal))
        {
            renderedGroupLimit = InitialGroupRenderLimit;
            lastRenderedPairKey = currentPairKey;
            groupCollapsedStates.Clear();
        }

        if (ComparisonResult != null)
        {
            await BuildDifferenceItemsAsync();
        }
        else
        {
            DifferenceItems = new List<DifferenceItem>();
            groupCollapsedStates.Clear();
        }
        
        // Reset full file view when pair changes
        var currentRawPairKey = $"{SelectedPair?.File1Path}|{SelectedPair?.File2Path}";
        if (currentRawPairKey != lastLoadedPairKey)
        {
            rawContentA = "";
            rawContentB = "";
            rawContentErrorMessage = null;
            lastLoadedPairKey = null;
            // Keep showFullFileView toggle state across pair changes but content needs reload
        }
        
        await base.OnParametersSetAsync();
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (showFullFileView && lastLoadedPairKey != $"{SelectedPair?.File1Path}|{SelectedPair?.File2Path}")
        {
            await LoadRawContentAsync();
        }
    }
    
    private async Task LoadRawContentAsync()
    {
        if (SelectedPair == null || isLoadingRawContent) return;
        
        var pairKey = $"{SelectedPair.File1Path}|{SelectedPair.File2Path}";
        if (pairKey == lastLoadedPairKey) return;
        
        isLoadingRawContent = true;
        rawContentErrorMessage = null;
        StateHasChanged();
        
        try
        {
            var result = await RawContentService.LoadRawContentAsync(SelectedPair);
            
            if (result.IsLoaded)
            {
                rawContentA = result.ContentA;
                rawContentB = result.ContentB;
                rawContentTruncatedA = result.IsTruncatedA;
                rawContentTruncatedB = result.IsTruncatedB;
            }
            else
            {
                rawContentErrorMessage = result.ErrorMessage;
            }
            
            lastLoadedPairKey = pairKey;
        }
        catch (Exception ex)
        {
            rawContentErrorMessage = $"Failed to load file content: {ex.Message}";
        }
        finally
        {
            isLoadingRawContent = false;
            StateHasChanged();
        }
    }
    
    private async Task BuildDifferenceItemsAsync()
    {
        var differences = (ComparisonResult?.Differences ?? Enumerable.Empty<Difference>()).ToList();
        var matches = AcceptedDifferenceService.IsEnabled
            ? await AcceptedDifferenceService.GetMatchesAsync(differences)
            : new Dictionary<string, AcceptedDifferenceProfile>(StringComparer.Ordinal);

        DifferenceItems = differences
            .Select(difference =>
            {
                var fingerprint = AcceptedDifferenceService.CreateFingerprint(difference);
                matches.TryGetValue(fingerprint.Fingerprint, out var matchedProfile);

                return new DifferenceItem
                {
                    SourceDifference = difference,
                    GroupKey = fingerprint.NormalizedPropertyPath,
                    Fingerprint = fingerprint.Fingerprint,
                    PropertyName = difference.PropertyName ?? string.Empty,
                    DisplayPropertyName = difference.PropertyName ?? string.Empty,
                    ExpectedValue = FormatValue(difference.Object1Value),
                    ActualValue = FormatValue(difference.Object2Value),
                    MatchedProfile = matchedProfile,
                };
            })
            .ToList();

        foreach (var group in DifferenceItems.GroupBy(item => item.GroupKey).OrderBy(group => group.Key))
        {
            if (!groupCollapsedStates.ContainsKey(group.Key))
            {
                groupCollapsedStates[group.Key] = true;
            }
        }
    }

    private IEnumerable<IGrouping<string, DifferenceItem>> GetFilteredGroups()
    {
        var filteredItems = DifferenceItems.AsEnumerable();
        if (HideTrackedDifferences)
        {
            filteredItems = filteredItems.Where(item => !IsSuppressibleTrackedDifference(item.MatchedProfile));
        }

        if (!string.IsNullOrWhiteSpace(SearchFilter))
        {
            var filter = SearchFilter.Trim();
            var includeValueSearch = filter.Length >= 3;

            filteredItems = filteredItems.Where(item =>
                item.GroupKey.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
                item.PropertyName.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
                (includeValueSearch && item.ExpectedValue.Contains(filter, StringComparison.OrdinalIgnoreCase)) ||
                (includeValueSearch && item.ActualValue.Contains(filter, StringComparison.OrdinalIgnoreCase)));
        }

        return filteredItems
            .GroupBy(item => item.GroupKey)
            .OrderBy(group => group.Key)
            .ToList();
    }

    private GroupRenderContext GetGroupRenderContext()
    {
        var filtered = GetFilteredGroups().ToList();

        return new GroupRenderContext
        {
            TotalCount = filtered.Count,
            Groups = filtered.Take(renderedGroupLimit).ToList(),
        };
    }

    private void LoadMoreGroups()
    {
        renderedGroupLimit += GroupRenderIncrement;
    }

    private void LoadAllGroups()
    {
        renderedGroupLimit = int.MaxValue;
    }
    
    private IEnumerable<DifferenceItem> GetGroupItems(IGrouping<string, DifferenceItem> group)
    {
        var items = ShowAllDifferences ? group : group.Take(GroupPreviewDifferenceLimit);
        foreach (var item in items)
        {
            item.DisplayPropertyName = GetRelativePropertyName(item.SourceDifference.PropertyName ?? string.Empty, group.Key);
        }

        return items;
    }

    private string GetRelativePropertyName(string fullPath, string groupKey)
    {
        if (string.IsNullOrEmpty(fullPath)) return "";

        var normalizedFull = PropertyPathNormalizer.NormalizePropertyPath(fullPath);
        if (groupKey == "(Root Properties)") return fullPath;
        
        if (normalizedFull.StartsWith(groupKey))
        {
            var relative = normalizedFull.Substring(groupKey.Length);
            var trimmed = relative.TrimStart('.', '[').TrimEnd(']');
            
            // If the relative path is empty, it means the full path matches the group key exactly.
            // In this case, we want to show the full path with the actual index (e.g., [5]) 
            // instead of the normalized path (which has [*]).
            if (string.IsNullOrEmpty(trimmed))
            {
                return fullPath;
            }
            
            return trimmed;
        }

        return fullPath;
    }

    private bool IsGroupCollapsed(string groupKey)
    {
        return groupCollapsedStates.TryGetValue(groupKey, out var isCollapsed) && isCollapsed;
    }

    private void ToggleGroupCollapse(string groupKey)
    {
        if (groupCollapsedStates.ContainsKey(groupKey))
        {
            groupCollapsedStates[groupKey] = !groupCollapsedStates[groupKey];
        }
        else
        {
            groupCollapsedStates[groupKey] = false;
        }
    }

    private async Task ExportResults()
    {
        await OnExportResults.InvokeAsync();
    }

    private async Task OpenProfileDialog(DifferenceItem item)
    {
        editingDifferenceItem = item;
        editorStatus = item.MatchedProfile?.Status ?? AcceptedDifferenceStatus.AcceptedDifference;
        editorTicketId = item.MatchedProfile?.TicketId ?? string.Empty;
        editorNotes = item.MatchedProfile?.Notes ?? string.Empty;
        profileDialogErrorMessage = null;
        showProfileDialog = true;
        await InvokeAsync(StateHasChanged);
    }

    private void CloseProfileDialog()
    {
        showProfileDialog = false;
        editingDifferenceItem = null;
        profileDialogErrorMessage = null;
    }

    private bool CanSaveProfile =>
        editingDifferenceItem != null &&
        (editorStatus != AcceptedDifferenceStatus.KnownBug || !string.IsNullOrWhiteSpace(editorTicketId));

    private async Task SaveProfileAsync()
    {
        if (editingDifferenceItem == null)
        {
            return;
        }

        try
        {
            var savedProfile = await AcceptedDifferenceService.SaveAsync(
                editingDifferenceItem.SourceDifference,
                editorStatus,
                editorNotes,
                editorTicketId);

            foreach (var item in DifferenceItems.Where(item => string.Equals(item.Fingerprint, savedProfile.Fingerprint, StringComparison.Ordinal)))
            {
                item.MatchedProfile = savedProfile;
            }

            CloseProfileDialog();
        }
        catch (Exception ex)
        {
            profileDialogErrorMessage = ex.Message;
        }
    }

    private async Task ClearProfileAsync()
    {
        if (editingDifferenceItem == null)
        {
            return;
        }

        try
        {
            var removed = await AcceptedDifferenceService.RemoveAsync(editingDifferenceItem.SourceDifference);
            if (removed)
            {
                foreach (var item in DifferenceItems.Where(item => string.Equals(item.Fingerprint, editingDifferenceItem.Fingerprint, StringComparison.Ordinal)))
                {
                    item.MatchedProfile = null;
                }
            }

            CloseProfileDialog();
        }
        catch (Exception ex)
        {
            profileDialogErrorMessage = ex.Message;
        }
    }

    private static bool IsSuppressibleTrackedDifference(AcceptedDifferenceProfile? profile) =>
        profile?.Status is AcceptedDifferenceStatus.AcceptedDifference or AcceptedDifferenceStatus.KnownBug;

    private int GetUntrackedDifferenceCount() => DifferenceItems.Count(item => item.MatchedProfile == null);

    private int GetAcceptedDifferenceCount() => DifferenceItems.Count(item => item.MatchedProfile?.Status == AcceptedDifferenceStatus.AcceptedDifference);

    private int GetKnownBugCount() => DifferenceItems.Count(item => item.MatchedProfile?.Status == AcceptedDifferenceStatus.KnownBug);

    private int GetFixedVerifiedCount() => DifferenceItems.Count(item => item.MatchedProfile?.Status == AcceptedDifferenceStatus.FixedVerified);

    private static string GetProfileLabel(AcceptedDifferenceProfile profile) => profile.Status switch
    {
        AcceptedDifferenceStatus.AcceptedDifference => "Accepted",
        AcceptedDifferenceStatus.KnownBug when !string.IsNullOrWhiteSpace(profile.TicketId) => $"Bug: {profile.TicketId}",
        AcceptedDifferenceStatus.KnownBug => "Known Bug",
        AcceptedDifferenceStatus.FixedVerified => "Fixed / Verified",
        _ => "Tracked",
    };

    private static Color GetProfileChipColor(AcceptedDifferenceStatus status) => status switch
    {
        AcceptedDifferenceStatus.AcceptedDifference => Color.Success,
        AcceptedDifferenceStatus.KnownBug => Color.Warning,
        AcceptedDifferenceStatus.FixedVerified => Color.Info,
        _ => Color.Default,
    };

    private string FormatValue(object? value)
    {
        if (value == null) return "null";

        if (value is DateTime dt)
            return dt.ToString("yyyy-MM-dd HH:mm:ss");

        var str = value.ToString() ?? "null";
        return str.Length > 100 ? str.Substring(0, 97) + "..." : str;
    }
}
